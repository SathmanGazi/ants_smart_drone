# Where artifacts live (relative paths resolved from backend/ cwd).
STORAGE_DIR=storage

# Detection
YOLO_MODEL=yolov8n.pt
YOLO_CONF_THRESHOLD=0.35
YOLO_IOU_THRESHOLD=0.5
# cpu | cuda:0 | mps  — use cuda on a GPU box for 3-10x speedup
YOLO_DEVICE=cpu
# Input resolution. 640 is the default. 480 is ~1.8x faster on CPU.
YOLO_IMGSZ=640

# Counting
MIN_HITS_TO_COUNT=6
MIN_STREAK=3
MIN_DISPLACEMENT_PX=35
STATIONARY_GRACE_FRAMES=60
REID_WINDOW_FRAMES=30
REID_DISTANCE_PX=60

# Runtime
PROGRESS_EVERY_N_FRAMES=10
FRAME_STRIDE=1
# 8 GB default upload limit. A 50-min 1080p MP4 is typically 3-5 GB.
MAX_UPLOAD_MB=8192

# CORS
CORS_ORIGINS=http://localhost:3000

# Optional counting ROI: polygon in pixel coords (x,y pairs, clockwise or ccw).
# Only tracks whose centroid sits inside this polygon are eligible to be counted.
# Leave empty to count across the whole frame.
# Example (1920x1080 frame, exclude a strip on the right and a side bridge on top):
# ROI_POLYGON_JSON=[[80,260],[1500,260],[1500,980],[80,980]]
ROI_POLYGON_JSON=
